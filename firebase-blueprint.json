{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A spare part product in the catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "string" },
        "reference": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "compatibility": {
          "type": "array",
          "items": { "type": "string" }
        },
        "specs": { "type": "object" }
      },
      "required": ["name", "brand", "reference", "price", "category", "image"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "facebook": { "type": "string" },
        "instagram": { "type": "string" },
        "linkedin": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/settings/general": {
      "schema": "Settings",
      "description": "Global site settings"
    }
  }
}
