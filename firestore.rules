// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: products
// Document ID: productId
// Fields:
//   - name: string (required)
//   - brand: string (required)
//   - model: string (optional)
//   - year: string (optional)
//   - reference: string (required)
//   - price: number (required)
//   - originalPrice: number (optional)
//   - image: string (required)
//   - category: string (required)
//   - rating: number (optional)
//   - reviewsCount: number (optional)
//   - compatibility: list (optional)
//   - specs: map (optional)
//
// Collection: users
// Document ID: userId
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string (optional)
//   - role: string (required, ['admin', 'user'])
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         ((request.auth.token.email == "souhailaetrachid@gmail.com" || request.auth.token.email == "rachiddmachmacha@gmail.com") && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'brand', 'reference', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() < 200 &&
             data.brand is string && data.brand.size() < 100 &&
             data.reference is string && data.reference.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string && data.image.size() < 2000;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
